APP_NAME=YTTSCRB
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=yttscrb
DB_USERNAME=yttscrb
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Workflow engine (durable-workflow/workflow on Redis)
WORKFLOW_CONNECTION=redis

# Transcription provider: groq (v1.0 default)
TRANSCRIPTION_PROVIDER=groq
GROQ_API_KEY=

# Summary provider: openai (v1.0 default)
SUMMARY_PROVIDER=openai
OPENAI_API_KEY=

# yt-dlp binary path (auto-detected if empty)
YT_DLP_BINARY=

# Maximum video duration in seconds (videos longer than this are rejected)
MAX_VIDEO_DURATION_SEC=7200

# Sentry error tracking (https://sentry.io)
SENTRY_DSN=
SENTRY_ENVIRONMENT=${APP_ENV}
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1

VITE_APP_NAME="${APP_NAME}"
