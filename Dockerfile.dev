FROM php:8.5-cli

# Install system dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        curl \
        git \
        libpq-dev \
        libzip-dev \
        nginx \
        python3 \
        python3-pip \
        ffmpeg \
        unzip \
    && pecl install redis \
    && docker-php-ext-enable redis \
    && docker-php-ext-install pdo_pgsql pcntl zip \
    && rm -rf /var/lib/apt/lists/*

# Install yt-dlp via pip (more up-to-date than apt)
RUN pip3 install --break-system-packages yt-dlp

# Install Node.js 22 LTS for frontend builds
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html

COPY . .

# Install PHP dependencies
RUN composer install --no-interaction --prefer-dist --no-progress

# Ensure storage directories are writable
RUN chmod -R 777 storage bootstrap/cache

# Remove .env file — production env comes from Kubernetes ConfigMap/Secret
RUN rm -f .env

# Install Node.js dependencies and build frontend
RUN npm install --legacy-peer-deps --ignore-scripts \
    && npm run build \
    && rm -rf node_modules

CMD php artisan optimize:clear \
    && cp -n vendor/durable-workflow/workflow/src/migrations/* database/migrations/ 2>/dev/null; \
    php artisan migrate --force \
    && (php artisan schedule:work &) \
    && exec php artisan serve --host=0.0.0.0 --port=80
