{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "yttscrb/app",
    "type": "project",
    "description": "YouTube Transcriber and Summarizer Micro-SaaS.",
    "keywords": ["laravel", "youtube", "transcription", "summarization"],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-curl": "*",
        "durable-workflow/waterline": "^1.0",
        "durable-workflow/workflow": "^1.0",
        "laravel/ai": "^0.6.7",
        "laravel/framework": "^13.7",
        "laravel/horizon": "^5.46",
        "laravel/tinker": "^3.0",
        "sentry/sentry-laravel": "^4.25",
        "spatie/laravel-sitemap": "^8.1",
        "webmozart/assert": "^2.3",
        "zircote/swagger-php": "^6.1"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5.12",
        "qossmic/deptrac-shim": "^1.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "tests/Support/helpers.php"
        ]
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "check": [
            "@php -d memory_limit=512M vendor/bin/phpstan analyse --level=9 --no-progress",
            "@php vendor/bin/phpcs --standard=PSR12 --warning-severity=0 app/ tests/",
            "@php vendor/bin/deptrac analyze",
            "@php vendor/bin/pest --compact"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
