**Create:** `resources/js/components/TutorialChecklist.vue`

Interactive checklist component:
- Shows only when `tutorialSteps.length > 0`
- Each step: checkbox (persisted in localStorage), step number, timecode button, action text
- Clicking timecode calls `onSeek` to jump YouTube player
- Completed steps get strikethrough + dimmed styling
- Progress counter: "3/12 steps completed"

```vue
<template>
  <div v-if="steps.length" class="space-y-3">
    <div class="flex items-center justify-between mb-1">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider flex items-center gap-2">
        <svg class="w-3.5 h-3.5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
        </svg>
        Step-by-Step Checklist
      </h3>
      <span class="text-xs text-gray-500">{{ completedCount }}/{{ steps.length }} done</span>
    </div>

    <div class="space-y-1.5">
      <div
        v-for="s in steps"
        :key="s.step"
        :class="[
          'flex items-start gap-3 rounded-lg p-2.5 border transition-all',
          isCompleted(s.step)
            ? 'bg-gray-800/30 border-gray-700/30'
            : 'bg-gray-800/60 border-gray-700 hover:border-orange-500/30'
        ]"
      >
        <!-- Checkbox -->
        <input
          type="checkbox"
          :checked="isCompleted(s.step)"
          @change="toggleStep(s.step)"
          class="mt-0.5 w-4 h-4 rounded border-gray-600 bg-gray-700 text-orange-500 focus:ring-orange-500/30 shrink-0"
        />

        <!-- Step content -->
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2 mb-0.5">
            <span :class="isCompleted(s.step) ? 'text-gray-600' : 'text-gray-400'" class="text-xs font-mono font-medium">
              Step {{ s.step }}
            </span>
            <button
              v-if="onSeek"
              @click="onSeek(timeToSeconds(s.time))"
              class="text-xs font-mono text-blue-400 hover:text-blue-300 bg-blue-500/10 hover:bg-blue-500/20 px-1.5 py-0.5 rounded border border-blue-500/20 transition-colors shrink-0"
              title="Jump to {{ s.time }}"
            >
              {{ s.time }}
            </button>
            <span v-else class="text-xs font-mono text-blue-400/60">{{ s.time }}</span>
          </div>
          <p :class="isCompleted(s.step) ? 'text-gray-600 line-through' : 'text-gray-200'" class="text-sm leading-relaxed">
            {{ s.action }}
          </p>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed } from 'vue';

const props = defineProps({
  steps: { type: Array, required: true },
  taskId: { type: String, default: null },
  onSeek: { type: Function, default: null },
});

const storageKey = computed(() => `tutorial_${props.taskId ?? 'global'}`);

const completed = ref(new Set(
  JSON.parse(localStorage.getItem(storageKey.value) ?? '[]')
));

const completedCount = computed(() => completed.value.size);

function isCompleted(step) {
  return completed.value.has(step);
}

function toggleStep(step) {
  const next = new Set(completed.value);
  if (next.has(step)) {
    next.delete(step);
  } else {
    next.add(step);
  }
  completed.value = next;
  localStorage.setItem(storageKey.value, JSON.stringify([...next]));
}

function timeToSeconds(time) {
  const parts = time.split(':').map(Number);
  if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
  return parts[0] * 60 + parts[1];
}
</script>
```

