{
  "manifest_version": 3,
  "name": "TubeSum — AI YouTube Summarizer",
  "version": "1.0.0",
  "description": "Instantly summarize any YouTube video with AI. Get key points and clickbait detection without leaving YouTube.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://tubesum.app/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-f-eS_gSR.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "TubeSum",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "resources": [
        "assets/content-script.ts-f-eS_gSR.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
