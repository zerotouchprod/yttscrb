{
  "manifest_version": 3,
  "name": "TubeSum — AI YouTube Summarizer",
  "version": "1.0.0",
  "description": "Instantly summarize any YouTube video with AI. Get key points and clickbait detection without leaving YouTube.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://tubesum.app/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "TubeSum",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
